Screen {
    layout: vertical;
}

#main-pane {
    height: 1fr;
    layout: horizontal;
}

#host-table {
    width: 3fr;
    min-width: 60;
}

#details-panel {
    width: 2fr;
    border: round $accent;
    padding: 1 2;
}

#status-strip {
    height: 3;
    padding: 0 1;
    border-top: solid $panel;
    content-align: left middle;
}

#dialog {
    width: 60;
    height: auto;
    padding: 1 2;
    border: round $primary;
    background: $surface;
}

.dialog-title {
    text-style: bold;
    margin-bottom: 1;
}

.dialog-actions {
    margin-top: 1;
    align: right middle;
    height: auto;
}

#dialog-error {
    color: $error;
    height: 1;
}

